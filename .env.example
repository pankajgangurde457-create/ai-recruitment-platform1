# ==========================================================
# CLIENT FRONTEND CONFIGURATION (Vite React App)
# ==========================================================

# Supabase API endpoint configuration
VITE_SUPABASE_URL=https://your-supabase-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-public-api-key-string

# ==========================================================
# SERVER BACKEND CONFIGURATION (Node.js Express App)
# ==========================================================

# Server execution port
PORT=5000

# Environment execution mode (development, production)
NODE_ENV=development

# Supabase Admin access settings
SUPABASE_URL=https://your-supabase-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-secret-key-string

# Google Gemini API key configuration (for resume parsing, scoring and chatbot assistant)
# Get a key from: https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key-from-google-ai-studio
